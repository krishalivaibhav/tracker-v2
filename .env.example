# Neon Postgres — https://neon.tech (or Vercel → Storage → Create Database → Neon)
# After creating the DB, copy the connection string from the dashboard
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Google OAuth credentials
# Create at: https://console.cloud.google.com
#   1. Create a project (or use an existing one)
#   2. APIs & Services → Credentials → Create → OAuth client ID
#   3. Application type: Web application
#   4. Authorised redirect URI: http://localhost:3000/api/auth/callback
#      (add your Vercel domain here too when you deploy)
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Any random 32+ character string — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_random_secret_here

# Groq AI — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# App base URL (no trailing slash)
APP_URL=https://your-app.vercel.app

# Adzuna job search — https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
ADZUNA_COUNTRY=in
